{
  "name": "rodocsmcp",
  "version": "1.0.0",
  "description": "Typed scraper and MCP server for the Roblox Creator Hub API Reference.",
  "author": "iamthebestts",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "rodocsmcp": "./dist/cli.js",
    "rodocs": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "dev:actor": "tsx src/cli/index.ts Actor",
    "dev:list": "tsx src/cli/index.ts --list",
    "dev:mcp": "tsx src/cli/index.ts --stdio",
    "build": "tsup",
    "start": "node dist/cli.js",
    "start:mcp": "node dist/cli.js --stdio",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "ci": "biome ci . && tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run ci && pnpm run build"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.15.1",
    "cheerio": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0",
    "domhandler": "*",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.29.1"
}
